#!/bin/bash
# Invalidate sudo credentials whenever the screen is locked.
# Listens to org.freedesktop.ScreenSaver.ActiveChanged on the session bus.
dbus-monitor --session "type='signal',interface='org.freedesktop.ScreenSaver',member='ActiveChanged'" 2>/dev/null |
  while read -r line; do
    if echo "$line" | grep -q "boolean true"; then
      sudo -K
    fi
  done
