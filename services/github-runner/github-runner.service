[Unit]
Description=GitHub Actions self-hosted runner
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=github-runner
Group=github-runner
WorkingDirectory=/var/lib/github-runner
ExecStart=/var/lib/github-runner/bin/runsvc.sh
Restart=always
RestartSec=10
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=5min

[Install]
WantedBy=multi-user.target
