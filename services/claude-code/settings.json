{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Edit",
      "Write",
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "mcp__linear-server__*",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Google_Drive__list_recent_files",
      "mcp__claude_ai_Google_Drive__get_file_metadata",
      "mcp__claude_ai_Google_Drive__get_file_permissions",
      "mcp__claude_ai_Google_Drive__read_file_content",
      "mcp__claude_ai_Google_Drive__download_file_content"
    ],
    "ask": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(sudo*)",
      "Bash(git push --delete*)",
      "Bash(git push * :*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -df*)",
      "Bash(git branch -D*)",
      "Bash(git rebase -i*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",
      "Bash(gh repo delete*)",
      "Bash(gh pr close*)",
      "Bash(gh release delete*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push:* main)",
      "Bash(git push:* master)"
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "$HOME/.claude/hooks/format.sh" }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [{ "type": "command", "command": "$HOME/.claude/hooks/sync-base.sh" }]
      },
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/load-context.sh" },
          { "type": "command", "command": "$HOME/.claude/hooks/worktree-env.sh" },
          { "type": "command", "command": "$HOME/.claude/hooks/ensure-env.sh" }
        ]
      }
    ]
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "Normal (non-force) git pushes to any branch except main/master.",
      "All gh CLI commands for creating and reading PRs, issues, and runs."
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "effort": "max",
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true
}
